{
  "workspace": "{workspace-name}",
  "created": "{YYYY-MM-DD}",
  "groom_cadence": "weekly",
  "groom_day": "friday",
  "areas": {
    "working-memory": {
      "type": "working-memory",
      "description": "Core context documents that AI reads every session",
      "paths": [
        ".base/data/active.json",
        ".base/data/backlog.json",
        ".base/data/projects.json"
      ],
      "groom": "weekly",
      "audit": {
        "strategy": "staleness",
        "config": {
          "threshold_days": 7
        }
      }
    },
    "projects": {
      "type": "directory",
      "description": "Project documentation and planning",
      "paths": [
        "projects/"
      ],
      "groom": "monthly",
      "audit": {
        "strategy": "classify",
        "config": {
          "states": ["active", "archive", "delete"],
          "archive_path": "projects/_archive/"
        }
      }
    },
    "tools": {
      "type": "config-cross-ref",
      "description": "MCP servers, personal tools, shareable tools",
      "paths": [
        "tools/"
      ],
      "groom": "monthly",
      "audit": {
        "strategy": "cross-reference",
        "config": {
          "config_file": ".mcp.json"
        }
      }
    },
    "system-layer": {
      "type": "system-layer",
      "description": "Claude Code commands, hooks, skills, CARL domains",
      "paths": [
        ".claude/commands/",
        ".claude/hooks/",
        ".claude/skills/",
        ".carl/"
      ],
      "groom": "monthly",
      "audit": {
        "strategy": "dead-code",
        "config": {
          "reference_check": true
        }
      }
    }
  },
  "carl_hygiene": {
    "proactive": true,
    "cadence": "monthly",
    "staleness_threshold_days": 60,
    "max_rules_per_domain": 15,
    "last_run": null
  },
  "surfaces": {
    "active": {
      "file": "data/active.json",
      "description": "Active work items, projects, and tasks",
      "hook": true,
      "silent": true,
      "schema": {
        "id_prefix": "ACT",
        "required_fields": ["title", "status", "priority"],
        "priority_levels": ["urgent", "high", "medium", "ongoing", "deferred"],
        "status_values": ["active", "blocked", "deferred", "done", "paused"]
      }
    },
    "backlog": {
      "file": "data/backlog.json",
      "description": "Future work queue, ideas, and deferred tasks",
      "hook": true,
      "silent": true,
      "schema": {
        "id_prefix": "BL",
        "required_fields": ["title", "priority"],
        "priority_levels": ["high", "medium", "low"],
        "time_rules": {
          "review_by": {
            "high": 7,
            "medium": 14,
            "low": 30
          },
          "staleness_multiplier": 2
        }
      }
    }
  },
  "satellites": {}
}
